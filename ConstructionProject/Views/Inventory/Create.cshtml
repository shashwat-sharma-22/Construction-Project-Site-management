@{
    ViewData["Title"] = "Add Inventory Item";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>➕ Add Inventory Item</h1>
            <hr />

            <form asp-action="Create" method="post">
                <div class="form-group mb-3">
                    <label for="itemType" class="form-label">Item Type</label>
                    <select id="itemType" name="itemType" class="form-select" onchange="toggleItemType()">
                        <option value="">-- Select Type --</option>
                        <option value="equipment">Equipment</option>
                        <option value="material">Material</option>
                    </select>
                </div>

                <div id="equipmentFields" style="display: none;">
                    <div class="form-group mb-3">
                        <label for="equipmentName" class="form-label">Equipment Name</label>
                        <input type="text" id="equipmentName" name="equipmentName" class="form-control" placeholder="Enter equipment name" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="status" class="form-label">Status</label>
                        <select id="status" name="status" class="form-select">
                            <option value="AVAILABLE">Available</option>
                            <option value="IN_USE">In Use</option>
                            <option value="MAINTENANCE">Maintenance</option>
                        </select>
                    </div>
                </div>

                <div id="materialFields" style="display: none;">
                    <div class="form-group mb-3">
                        <label for="materialName" class="form-label">Material Name</label>
                        <input type="text" id="materialName" name="materialName" class="form-control" placeholder="Enter material name" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="quantity" class="form-label">Quantity</label>
                        <input type="number" id="quantity" name="quantity" class="form-control" placeholder="0" min="0" step="0.01" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="unitCost" class="form-label">Unit Cost</label>
                        <input type="number" id="unitCost" name="unitCost" class="form-control" placeholder="0.00" min="0" step="0.01" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="unit" class="form-label">Unit</label>
                        <input type="text" id="unit" name="unit" class="form-control" placeholder="e.g., kg, liter, meter" />
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary me-2">Add Item</button>
                    <a href="@Url.Action("Index", "Inventory")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function setSectionEnabled(sectionId, enabled) {
    const elements = document.querySelectorAll(`#${sectionId} input, #${sectionId} select, #${sectionId} textarea`);
    elements.forEach(e => e.disabled = !enabled);
}

function toggleItemType() {
    const itemType = document.getElementById('itemType').value;
    const isEquipment = itemType === 'equipment';
    const isMaterial = itemType === 'material';

    document.getElementById('equipmentFields').style.display = isEquipment ? 'block' : 'none';
    document.getElementById('materialFields').style.display = isMaterial ? 'block' : 'none';

    setSectionEnabled('equipmentFields', isEquipment);
    setSectionEnabled('materialFields', isMaterial);
}

document.addEventListener('DOMContentLoaded', toggleItemType);
</script>
