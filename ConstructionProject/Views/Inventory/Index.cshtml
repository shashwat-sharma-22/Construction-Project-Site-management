@model ConstructionProject.Models.InventoryIndexViewModel

@{
    ViewData["Title"] = "Inventory";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>🔧 Inventory Management</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Inventory")" class="btn btn-primary">
                <i class="bi bi-plus"></i> Add Item
            </a>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="equipment-tab" data-bs-toggle="tab" data-bs-target="#equipment" type="button" role="tab">Equipment</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="materials-tab" data-bs-toggle="tab" data-bs-target="#materials" type="button" role="tab">Materials</button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="equipment" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>EquipmentId</th>
                            <th>Name</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    
                    <tbody>
                    @if (Model.Equipments != null && Model.Equipments.Count > 0)
                    {
                        foreach (var equipment in Model.Equipments)
                        {
                            <tr>
                                <td>@equipment.EquipmentId</td>
                                <td>@equipment.Name</td>
                                <td>@equipment.Status</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">No equipment found.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab-pane fade" id="materials" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>MaterialId</th>
                            <th>Name</th>
                            <th>QuantityAvailable</th>
                            <th>UnitCost</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Materials != null && Model.Materials.Count > 0)
                    {
                        foreach (var material in Model.Materials)
                        {
                            <tr>
                                <td>@material.MaterialId</td>
                                <td>@material.Name</td>
                                <td>@material.QuantityAvailable</td>
                                <td>@material.UnitCost</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">No materials found.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
