@model ConstructionProject.Models.ProjectTask

@{
    ViewData["Title"] = "Create Task";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>📝 Create New Task for @ViewData["ProjectName"]</h1>
            <hr />

            <form asp-action="Create" asp-controller="Task" asp-route-projectId="@ViewData["ProjectId"]" method="post">
                <input type="hidden" asp-for="ProjectId" />

                <div class="form-group mb-3">
                    <label asp-for="TaskName" class="form-label">Task Name</label>
                    <input asp-for="TaskName" class="form-control" placeholder="Enter task name" />
                    <span asp-validation-for="TaskName" class="text-danger small"></span>
                </div>

                @if (ViewData["UserRole"]?.ToString() != "ProjectManager")
                {
                    <div class="form-group mb-3">
                        <label asp-for="WorkerId" class="form-label">Assign To (Workforce Member)</label>
                        @if (((SelectList?)ViewBag.Workforce)?.Any() == true)
                        {
                            <select asp-for="WorkerId" asp-items="@(ViewBag.Workforce as SelectList)" class="form-select">
                                <option value="">-- Select Worker --</option>
                            </select>
                        }
                        else
                        {
                            <select asp-for="WorkerId" class="form-select" disabled>
                                <option value="">-- No contractor assigned to this project --</option>
                            </select>
                            <small class="text-muted">A contractor must be assigned to this project before workforce can be assigned to tasks.</small>
                        }
                        <span asp-validation-for="WorkerId" class="text-danger small"></span>
                    </div>
                }

                <div class="form-group mb-3">
                    <label asp-for="Deadline" class="form-label">Deadline</label>
                    <input asp-for="Deadline" type="date" class="form-control" />
                    <span asp-validation-for="Deadline" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<ConstructionProject.Models.TaskStatus>()" class="form-select"></select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary me-2">Create</button>
                    <a href="@Url.Action("Index", "Task", new { projectId = ViewData["ProjectId"] })" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
