@model ConstructionProject.Models.ProjectTask

@{
    ViewData["Title"] = "Task Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>📝 Task Details</h1>
            <hr />

            <dl class="row">
                <dt class="col-sm-4">Task ID</dt>
                <dd class="col-sm-8">@Model.TaskId</dd>

                <dt class="col-sm-4">Task Name</dt>
                <dd class="col-sm-8">@Model.TaskName</dd>

                <dt class="col-sm-4">Project</dt>
                <dd class="col-sm-8">@Model.Project?.ProjectName</dd>

                <dt class="col-sm-4">Assigned To</dt>
                <dd class="col-sm-8">@(Model.Worker != null ? $"{Model.Worker.Name} ({Model.Worker.Role})" : "Not Assigned")</dd>

                <dt class="col-sm-4">Deadline</dt>
                <dd class="col-sm-8">@Model.Deadline.ToString("MMM dd, yyyy")</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">
                    @if (Model.Status == ConstructionProject.Models.TaskStatus.COMPLETED)
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                    else if (Model.Status == ConstructionProject.Models.TaskStatus.IN_PROGRESS)
                    {
                        <span class="badge bg-warning text-dark">In Progress</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pending</span>
                    }
                </dd>
            </dl>

            <div>
                <a href="@Url.Action("Edit", "Task", new { id = Model.TaskId })" class="btn btn-warning me-2">Edit</a>
                <a href="@Url.Action("Index", "Task", new { projectId = Model.ProjectId })" class="btn btn-secondary me-2">Back to Tasks</a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">🏠 Dashboard</a>
            </div>
        </div>
    </div>
</div>
