@model IEnumerable<ConstructionProject.Models.ProjectTask>

@{
    ViewData["Title"] = "Tasks - " + ViewData["ProjectName"];
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>📝 Tasks for @ViewData["ProjectName"]</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Task", new { projectId = ViewData["ProjectId"] })" class="btn btn-primary">
                <i class="bi bi-plus"></i> New Task
            </a>
            <a href="@Url.Action("Index", "Project")" class="btn btn-outline-secondary">
                Back to Projects
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                🏠 Dashboard
            </a>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <form method="get" asp-action="Index" asp-controller="Task" asp-route-projectId="@ViewData["ProjectId"]" class="d-flex">
                <input type="text" name="search" value="@ViewData["CurrentSearch"]" class="form-control me-2" placeholder="Search by Task ID or Name..." />
                <button type="submit" class="btn btn-outline-primary me-2">Search</button>
                <a href="@Url.Action("Index", "Task", new { projectId = ViewData["ProjectId"] })" class="btn btn-outline-secondary">Clear</a>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Task Name</th>
                        <th>Assigned To</th>
                        <th>Deadline</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td>@task.TaskId</td>
                            <td><strong>@task.TaskName</strong></td>
                            <td>@(task.Worker?.Name ?? "Not Assigned")</td>
                            <td>@task.Deadline.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (task.Status == ConstructionProject.Models.TaskStatus.COMPLETED)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else if (task.Status == ConstructionProject.Models.TaskStatus.IN_PROGRESS)
                                {
                                    <span class="badge bg-warning text-dark">In Progress</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pending</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "Task", new { id = task.TaskId })" class="btn btn-info btn-sm">View</a>
                                <a href="@Url.Action("Edit", "Task", new { id = task.TaskId })" class="btn btn-warning btn-sm">Edit</a>
                                <form asp-action="Delete" asp-controller="Task" asp-route-id="@task.TaskId" method="post" style="display: inline;">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h5>No tasks found</h5>
            <p>Get started by creating a new task for this project.</p>
            <a href="@Url.Action("Create", "Task", new { projectId = ViewData["ProjectId"] })" class="btn btn-primary">Create Task</a>
        </div>
    }
</div>
