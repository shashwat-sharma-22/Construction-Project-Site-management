@model ConstructionProject.Models.Contractor

@{
    ViewData["Title"] = "Contractor Details";
    var isAdmin = string.Equals(User.FindFirst("role")?.Value ?? Context.Request.Cookies["userRole"], "Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">👷 @Model.ContractorName</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Contractor ID:</label>
                            <p>@Model.ContractorId</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Specialization:</label>
                            <p>@Model.Specialization</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Contact Info:</label>
                            <p>@Model.ContactInfo</p>
                        </div>
                    </div>

                    @if (Model.Workforces?.Any() == true)
                    {
                        <div class="mt-3">
                            <h5>👥 Assigned Workforce</h5>
                            <ul class="list-group">
                                @foreach (var workforce in Model.Workforces)
                                {
                                    <li class="list-group-item">
                                        <strong>@workforce.Name</strong> - @workforce.Role
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="mt-4">
                        @if (isAdmin)
                        {
                            <a href="@Url.Action("Edit", "Contractor", new { id = Model.ContractorId })" class="btn btn-warning me-2">Edit</a>
                            <form asp-action="Delete" asp-controller="Contractor" asp-route-id="@Model.ContractorId" method="post" style="display:inline;" class="me-2">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        }
                        <a href="@Url.Action("Index", "Contractor")" class="btn btn-secondary me-2">Back to Contractors</a>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">🏠 Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
