@{
    ViewData["Title"] = "404 - Page Not Found";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-page">
                <h1 class="display-1 text-danger fw-bold">404</h1>
                <h2 class="h3 mb-3 text-dark">Oops! Page Not Found</h2>
                <p class="lead text-muted mb-4">
                    Sorry, the page you're looking for doesn't exist or may have been moved.
                </p>

                @if (ViewData["RequestPath"] != null)
                {
                    <p class="text-muted mb-4">
                        <strong>Requested URL:</strong> <code>@ViewData["RequestPath"]</code>
                    </p>
                }

                <div class="mb-4">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg me-2">
                        <i class="bi bi-house"></i> Go Home
                    </a>
                    <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                        <i class="bi bi-arrow-left"></i> Go Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .error-page {
        padding: 50px 0;
        min-height: 500px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
</style>
