@model IEnumerable<ConstructionProject.DTOs.UserResponseDto>

@{
    ViewData["Title"] = "Users";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Users</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("register", "User")" class="btn btn-primary">
                <i class="bi bi-plus"></i> New User
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>User Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Is Active</th>
                        <th>Joining Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@user.Name</strong></td>
                            <td>@user.Email</td>
                            <td>@user.Role</td>
                            <td>@(user.IsActive ? "Yes" : "No")</td>
                            <td>
                                <a href="@Url.Action("Details", "User", new { id = user.UserId })" class="btn btn-info btn-sm">View</a>
                                @* <a href="@Url.Action("UpdateRole", "User", new { id = user.UserId })" class="btn btn-warning btn-sm">Update Role</a> *@
                                <form asp-action="Delete" asp-controller="User" asp-route-id="@user.UserId" method="post" style="display: inline;">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?)">
                                        Delete
                                    </button>
                                </form>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h5>No User found</h5>
            <p>Get started by creating a new user.</p>
            <a href="@Url.Action("register", "User")" class="btn btn-primary">Create User</a>
        </div>
    }
</div>
