@model ConstructionProject.Models.AppUser

@{
    ViewData["Title"] = "Create User";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>📋 Create New User</h1>
            <hr />

            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label">User Name</label>
                    <input asp-for="Name" type="text" class="form-control" placeholder="Enter user name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Enter user email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PasswordHash" class="form-label">Password</label>
                    <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Enter user password" />
                    <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Role" class="form-label">User Role</label>
                    <input asp-for="Role" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    <select name="role" class="form-select" required asp-for="Role">
                        <option value="">-- Select User Role --</option>
                        <option value="1">Project Manager - Manage Projects</option>
                        <option value="2">Site Engineer - Field Operations</option>
                        <option value="3">Contractor - Resource Management</option>
                        <option value="4">Safety Officer - Safety Management</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary me-2">Create</button>
                    <a href="@Url.Action("Index", "User")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
