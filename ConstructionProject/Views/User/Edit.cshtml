@model ConstructionProject.DTOs.UserResponseDto

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">✏️ Edit User: @Model.Name</h4>
                </div>
                <div class="card-body">
                    <form id="editUserForm">
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">User ID</label>
                            <input type="text" class="form-control" value="@Model.UserId" disabled />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Name</label>
                            <input type="text" class="form-control" value="@Model.Name" disabled />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control" value="@Model.Email" disabled />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Joining Date</label>
                            <input type="text" class="form-control" value="@Model.CreatedAt.ToString("MMMM dd, yyyy")" disabled />
                        </div>

                        <div class="form-group mb-3">
                            <label for="role" class="form-label fw-bold">User Role *</label>
                            <select id="role" class="form-select" required data-role="@Model.Role">
                                <option value="">-- Select User Role --</option>
                                <option value="0">Admin</option>
                                <option value="1">Project Manager - Manage Projects</option>
                                <option value="2">Site Engineer - Field Operations</option>
                                <option value="3">Contractor - Resource Management</option>
                                <option value="4">Safety Officer - Safety Management</option>
                            </select>
                            <small class="text-muted d-block mt-2">Current Role: <strong>@Model.Role</strong></small>
                        </div>

                        <div class="form-group mb-3">
                            <label for="status" class="form-label fw-bold">Status *</label>
                            <select id="status" class="form-select" required data-status="@Model.IsActive">
                                <option value="">-- Select Status --</option>
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary me-2">Save Changes</button>
                            <a href="@Url.Action("Index", "User")" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const roleSelect = document.getElementById('role');
        const statusSelect = document.getElementById('status');
        
        const roleMap = { 'Admin': '0', 'ProjectManager': '1', 'SiteEngineer': '2', 'Contractor': '3', 'SafetyOfficer': '4' };
        roleSelect.value = roleMap[roleSelect.dataset.role] || '';
        statusSelect.value = roleSelect.dataset.status === 'True' ? 'true' : 'false';

        document.getElementById('editUserForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const userId = @Model.UserId;
            const roleValue = roleSelect.value;
            const statusValue = statusSelect.value;

            if (!roleValue || !statusValue) {
                alert('Please select role and status');
                return;
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                
                await fetch(`/User/${userId}/role`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ newRole: parseInt(roleValue) })
                });

                const endpoint = statusValue === 'true' ? 'activate' : 'deactivate';
                await fetch(`/User/${userId}/${endpoint}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }
                });

                alert('User updated successfully!');
                window.location.href = '@Url.Action("Index", "User")';
            } catch (error) {
                alert('Error: ' + error.message);
            }
        });
    </script>
}
