@model ConstructionProject.Models.Progress

@{
    ViewData["Title"] = "Log Progress";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>📝 Log Project Progress</h1>
            <hr />

            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label asp-for="ProjectId" class="form-label">Project ID</label>
                    <input asp-for="ProjectId" type="number" class="form-control" placeholder="Enter project ID" />
                    <span asp-validation-for="ProjectId" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ReportDate" class="form-label">Report Date</label>
                    <input asp-for="ReportDate" type="date" class="form-control" />
                    <span asp-validation-for="ReportDate" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CompletedTasks" class="form-label">Completed Tasks</label>
                    <input asp-for="CompletedTasks" type="number" class="form-control" placeholder="0" />
                    <span asp-validation-for="CompletedTasks" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Remarks" class="form-label">Remarks</label>
                    <textarea asp-for="Remarks" class="form-control" rows="4" placeholder="Add any remarks about the progress"></textarea>
                    <span asp-validation-for="Remarks" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary me-2">Log Progress</button>
                    <a href="@Url.Action("Index", "Progress")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
