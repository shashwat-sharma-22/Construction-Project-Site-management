@model ConstructionProject.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>✏️ Edit Project</h1>
            <hr />

            <form asp-action="Edit">
                <input type="hidden" asp-for="ProjectId" />
                
                <div class="form-group mb-3">
                    <label asp-for="ProjectName" class="form-label">Project Name</label>
                    <input asp-for="ProjectName" class="form-control" />
                    <span asp-validation-for="ProjectName" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="startDate" class="form-label">Start Date</label>
                    <input asp-for="startDate" type="date" class="form-control" />
                    <span asp-validation-for="startDate" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="endDate" class="form-label">End Date</label>
                    <input asp-for="endDate" type="date" class="form-control" />
                    <span asp-validation-for="endDate" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="budget" class="form-label">Budget ($)</label>
                    <input asp-for="budget" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="budget" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary me-2">Save Changes</button>
                    <a href="@Url.Action("Index", "Project")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
