@model IEnumerable<ConstructionProject.Models.Project>

@{
    ViewData["Title"] = "Assign Contractor to Project";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>🔗 Assign Contractor to Project</h1>
            <p class="text-muted">Search for a project by ID or name, then assign a contractor.</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Project")" class="btn btn-outline-secondary">Back to Projects</a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">🏠 Dashboard</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-8">
            <form method="get" asp-action="AssignContractor" asp-controller="Project" class="d-flex">
                <input type="text" name="search" value="@ViewData["CurrentSearch"]" class="form-control me-2" placeholder="Search by Project ID or Name..." />
                <button type="submit" class="btn btn-outline-primary me-2">Search</button>
                <a href="@Url.Action("AssignContractor", "Project")" class="btn btn-outline-secondary">Clear</a>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Project Name</th>
                        <th>Current Contractor</th>
                        <th>Assign Contractor</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var project in Model)
                    {
                        <tr>
                            <td>@project.ProjectId</td>
                            <td><strong>@project.ProjectName</strong></td>
                            <td>
                                @if (project.Contractor != null)
                                {
                                    <span class="badge bg-success">@project.Contractor.ContractorName</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Not Assigned</span>
                                }
                            </td>
                            <td>
                                <form method="post" asp-action="AssignContractor" asp-controller="Project" class="d-flex align-items-center">
                                    <input type="hidden" name="projectId" value="@project.ProjectId" />
                                    <select name="contractorId" class="form-select form-select-sm me-2" style="max-width: 200px;">
                                        <option value="">-- None --</option>
                                        @foreach (var contractor in (SelectList)ViewBag.Contractors)
                                        {
                                            <option value="@contractor.Value" selected="@(contractor.Value == project.ContractorId?.ToString())">@contractor.Text</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">Assign</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h5>No projects found</h5>
            <p>Try a different search term.</p>
        </div>
    }
</div>
