@model ConstructionProject.Models.SafetyInspection

@{
    ViewData["Title"] = "Create Safety Inspection";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>📋 Create Safety Inspection Report</h1>
            <hr />

            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label asp-for="ProjectId" class="form-label">Project ID</label>
                    <input asp-for="ProjectId" type="number" class="form-control" placeholder="Enter project ID" />
                    <span asp-validation-for="ProjectId" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="InspectionDate" class="form-label">Inspection Date</label>
                    <input asp-for="InspectionDate" type="date" class="form-control" />
                    <span asp-validation-for="InspectionDate" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ComplianceStatus" class="form-label">Compliance Status</label>
                    <select asp-for="ComplianceStatus" class="form-select">
                        <option value="COMPLIANT">✓ Compliant</option>
                        <option value="NON_COMPLIANT">✗ Non-Compliant</option>
                    </select>
                    <span asp-validation-for="ComplianceStatus" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="IssuesFound" class="form-label">Issues Found</label>
                    <textarea asp-for="IssuesFound" class="form-control" rows="4" placeholder="Describe any safety issues or leave blank if none"></textarea>
                    <span asp-validation-for="IssuesFound" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary me-2">Create Report</button>
                    <a href="@Url.Action("Index", "Safety")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
